# API
DATABASE_URL="postgresql://flux:flux@localhost:5432/flux?schema=public"
BETTER_AUTH_SECRET="change-me-to-a-32-char-or-longer-random-string"
BETTER_AUTH_URL="https://flux-api.kepler-industries.com"
PUBLIC_APP_SCHEME="flux"
PORT=3000
TRUSTED_ORIGINS="flux://,https://flux-api.kepler-industries.com"

# OAuth (optional — leave blank to disable that provider)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Mobile (apps/mobile/.env)
EXPO_PUBLIC_API_URL="https://flux-api.kepler-industries.com"
